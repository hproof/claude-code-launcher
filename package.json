{
  "name": "claude-code-launcher",
  "displayName": "Claude Code Launcher",
  "description": "在 VS Code 中快速启动 Claude Code",
  "version": "1.0.0",
  "publisher": "hproof",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "ai",
    "terminal"
  ],
  "activationEvents": [
    "onCommand:claude-code-launcher.launch"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hproof/claude-code-launcher.git"
  },
  "bugs": {
    "url": "https://github.com/hproof/claude-code-launcher/issues"
  },
  "homepage": "https://github.com/hproof/claude-code-launcher#readme",
  "license": "MIT",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-code-launcher.launch",
        "title": "Launch Claude Code",
        "category": "Claude Code"
      }
    ],
    "configuration": {
      "title": "Claude Code Launcher",
      "properties": {
        "claudeCodeLauncher.terminalMode": {
          "type": "string",
          "default": "external",
          "enum": [
            "integrated",
            "external"
          ],
          "enumDescriptions": [
            "使用 VS Code 内置终端",
            "使用独立的外部终端窗口（默认）"
          ],
          "description": "终端模式"
        },
        "claudeCodeLauncher.externalTerminal": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "cmd",
            "powershell",
            "wt",
            "gnome",
            "konsole",
            "xterm"
          ],
          "enumDescriptions": [
            "自动检测系统默认终端",
            "Windows CMD",
            "Windows PowerShell",
            "Windows Terminal",
            "Linux GNOME Terminal",
            "Linux Konsole",
            "Linux XTerm"
          ],
          "description": "外部终端类型（仅当 terminalMode 为 external 时有效）"
        },
        "claudeCodeLauncher.command": {
          "type": "string",
          "default": "claude",
          "description": "Claude Code 启动命令，可包含参数和路径，例如 'claude'、'claude.exe -c'、'd:/myself/claude.exe -c'"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "18.x",
    "typescript": "^5.3.2",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0"
  }
}
